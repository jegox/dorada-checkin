generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Shift {
  id         String       @id @default(cuid())
  name       String
  startTime  String
  endTime    String
  employees  Employee[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Employee {
  id           String                @id @default(cuid())
  document     String                @unique
  fullName     String
  position     String
  active       Boolean               @default(true)
  deviceCode   String?               @unique
  baseSalary   Decimal               @default(0) @db.Decimal(12, 2)
  salaryPeriod String                @default("MENSUAL") // "DIA" | "MENSUAL"
  shiftId      String
  shift        Shift                 @relation(fields: [shiftId], references: [id])
  attendances  Attendance[]
  payrollRules EmployeePayrollRule[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model Attendance {
  id         String           @id @default(cuid())
  employeeId String
  employee   Employee         @relation(fields: [employeeId], references: [id])
  type       AttendanceType
  status     AttendanceStatus
  createdAt  DateTime         @default(now())
}

enum AttendanceType {
  CHECK_IN
  CHECK_OUT
}

enum AttendanceStatus {
  ON_TIME
  LATE
  EARLY
}

enum PayrollRuleType {
  DESCUENTO
  CREDITO
  BONO
  TURNO_EXTRA
}

model PayrollRule {
  id          String                @id @default(cuid())
  name        String
  type        PayrollRuleType
  amount      Decimal               @db.Decimal(12, 2)
  description String?
  active      Boolean               @default(true)
  period      String                @default("MENSUAL") // "DIA" | "MENSUAL"
  activeDays  Json?                 // null = siempre; [1,2,3,4,5] = días de semana (0=Dom…6=Sáb). Solo para tipo BONO.
  employees   EmployeePayrollRule[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model EmployeePayrollRule {
  id         String      @id @default(cuid())
  employeeId String
  ruleId     String
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  rule       PayrollRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())

  @@unique([employeeId, ruleId])
}
